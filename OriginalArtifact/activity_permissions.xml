<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sms_permissions_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".PermissionsActivity">

    <!--App name-->
    <TextView
        android:id="@+id/companyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textColor="@color/primary_dark_blue"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp" />

    <!--SMS Notifications message-->
    <TextView
        android:id="@+id/SMSMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/SMS_message"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/companyName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!--App name-->


    <TextView
        android:id="@+id/SMSDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:gravity="start"
        android:text="@string/enable_alerts_long"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/SMSMessage" />
    <!--decorative line -->
    <View
        android:layout_width="0dp"
        android:layout_height="2dp"
        app:layout_constraintTop_toBottomOf="@id/SMSDescription"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/primary_light_blue"
        android:layout_marginTop="8dp"/>

    <!--Linear Layout for enable switch-->
    <LinearLayout
        android:id="@+id/SMSSwitchLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/SMSDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/SMSSwitchLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/enable_alerts"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/enableSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!--decorative line under item number-->
    <View
        android:layout_width="0dp"
        android:layout_height="2dp"
        app:layout_constraintTop_toBottomOf="@id/SMSSwitchLayout"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/primary_light_blue"
        android:layout_marginTop="8dp"/>

    <!--request permission button-->
    <Button
        android:id="@+id/buttonCheckPermission"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/request_permission"
        android:backgroundTint="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/SMSSwitchLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/buttonGoBack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/go_back"
        android:backgroundTint="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/buttonCheckPermission"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>