<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/itemDetails"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".ItemDetailsActivity">

    <!--App name-->
    <TextView
        android:id="@+id/companyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textColor="@color/primary_dark_blue"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        android:layout_marginTop="40dp" />

    <!--item details message-->
    <TextView
        android:id="@+id/itemDetailsMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View or Update Item Details"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/companyName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!--item number-->
    <TextView
        android:id="@+id/itemNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/item_number"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/itemDetailsMessage"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="50dp" />

    <!--item number-->
    <EditText
        android:id="@+id/editItemNumber"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Item Number"
        android:text="Item Number"
        android:inputType="text|number"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/itemNumber"
        app:layout_constraintStart_toEndOf="@id/itemNumber"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp" />

    <!--item description-->
    <TextView
        android:id="@+id/itemDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/item_desc"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/itemNumber"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <!--item description-->
    <EditText
        android:id="@+id/editItemDescription"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Description"
        android:text="Description"
        android:inputType="text"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/itemDescription"
        app:layout_constraintStart_toEndOf="@id/itemDescription"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="10dp" />

    <!--item location-->
    <TextView
        android:id="@+id/itemLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/item_loc"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/itemDescription"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp" />

    <!--item location-->
    <EditText
        android:id="@+id/editItemLocation"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Location"
        android:text="Item Location"
        android:inputType="text"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/itemLocation"
        app:layout_constraintStart_toEndOf="@id/itemLocation"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp" />

    <!--item quantity-->
    <TextView
        android:id="@+id/itemQuantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/item_qty"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/itemLocation"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <!--edit item quantity-->
    <EditText
        android:id="@+id/editItemQuantity"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Quantity"
        android:text="10"
        android:inputType="number"
        app:layout_constraintTop_toTopOf="@id/itemQuantity"
        app:layout_constraintStart_toEndOf="@id/itemQuantity"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp" />

    <!--min stock level-->
    <TextView
        android:id="@+id/minStockLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/min_stock_level"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/itemQuantity"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="36dp" />

    <!--edit min stock level-->
    <EditText
        android:id="@+id/editStockLevel"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Min stock"
        android:text="5"
        android:inputType="number"
        app:layout_constraintTop_toTopOf="@id/minStockLevel"
        app:layout_constraintStart_toEndOf="@id/minStockLevel"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp" />

    <!--linear layout for save changes and delete buttons-->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/editStockLevel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="50dp">

        <Button
            android:id="@+id/buttonSaveItemChanges"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/button_save"
            android:backgroundTint="@color/primary_blue"/>

        <Button
            android:id="@+id/buttonDeleteItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/button_delete"
            android:backgroundTint="@color/primary_blue"/>
    </LinearLayout>
    <Button
        android:id="@+id/buttonGoBack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/go_back"
        android:backgroundTint="@color/primary_blue"
        app:layout_constraintTop_toBottomOf="@id/layoutActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>