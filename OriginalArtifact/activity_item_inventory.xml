<?xml version="1.0" encoding="utf-8"?>
<!--card view for each item in inventory. allows the user to click on the
card to go to the item details page. has minor details to show the user
basic information about the item-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    card_view:cardCornerRadius="4dp"
    card_view:cardBackgroundColor="@color/alice_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <!--item name-->
        <TextView
            android:id="@+id/itemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/item_number"
            android:textStyle="bold"
            android:textSize="18sp"/>
        <!--decorative line under item number-->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/primary_light_blue"/>
        <!--item quantity-->
        <TextView
            android:id="@+id/itemQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/item_qty"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>
        <!--item location-->
        <TextView
            android:id="@+id/itemLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/item_loc"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
        <!--delete button -->
        <Button
            android:id="@+id/buttonDeleteItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_delete"
            android:backgroundTint="@color/primary_blue"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>